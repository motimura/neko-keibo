    "expo-file-system": "~55.0.10",
    "expo-linking": "~55.0.7",
    "expo-notifications": "~55.0.10",
    "expo-router": "~55.0.3",
    "expo-sharing": "~55.0.11",
    "expo-sqlite": "~55.0.10",
    "expo-standard-web-crypto": "^55.0.5",
    "expo-status-bar": "~55.0.4",
    "nativewind": "^4.2.2",
    "react": "19.2.0",
    "react-dom": "^19.2.0",
    "react-native": "0.83.2",
    "react-native-chart-kit": "^6.12.0",
    "react-native-gesture-handler": "~2.30.0",
